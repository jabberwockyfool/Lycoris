<Window x:Class="Lycoris.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:yk="clr-namespace:Lycoris.Yokai"
        x:Name="Root"
        Title="Lycoris — YKW3 Editor" Height="720" Width="900">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2,0,2"/>
        </Style>
        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#666"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Button x:Name="OpenFolderButton" Content="Ouvrir un dossier…" Padding="10,4" Click="OpenFolderButton_Click"/>
            <Button x:Name="AddButton" Content="+ Ajouter" Padding="10,4" Margin="6,0,0,0" Click="AddButton_Click" IsEnabled="False"/>
            <Button x:Name="SaveButton" Content="Sauver le mod" Padding="10,4" Margin="6,0,0,0" Click="SaveButton_Click" IsEnabled="False"/>
        </StackPanel>

        <!-- Selector -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <TextBlock Text="Yo-kai:"/>
            <ComboBox x:Name="Selector" Width="300" DisplayMemberPath="DisplayName"
                      SelectionChanged="Selector_SelectionChanged" IsTextSearchEnabled="True"/>
            <Button Content="◀" Width="30" Margin="6,0,0,0" Click="Prev_Click"/>
            <Button Content="▶" Width="30" Margin="3,0,0,0" Click="Next_Click"/>
            <TextBlock Text="Filtre:" Margin="16,0,4,0"/>
            <TextBox x:Name="FilterBox" Width="180" TextChanged="FilterBox_TextChanged"/>
        </StackPanel>

        <TextBlock x:Name="StatusText" DockPanel.Dock="Bottom" Margin="0,6,0,0" Foreground="#555"
                   TextWrapping="Wrap" Text="Ouvre un dossier extrait / mod YWML."/>

        <!-- Character panel -->
        <GroupBox Header="Character" x:Name="Panel" IsEnabled="False">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="8">
                    <!-- Header -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="72" Height="72" BorderBrush="#999" BorderThickness="1"
                                Background="#F0F0F0" Margin="0,0,12,0">
                            <Grid>
                                <TextBlock Text="{Binding ParamIdHex}" TextWrapping="Wrap" FontSize="9"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center"/>
                                <Image x:Name="PortraitImage" Stretch="Uniform" SnapsToDevicePixels="True"
                                       RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                <Button x:Name="ReplaceIconButton" Content="PNG…" FontSize="9" Padding="3,0"
                                        HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="1"
                                        Click="ReplaceIconButton_Click" ToolTip="Remplacer l'icône par un PNG"/>
                            </Grid>
                        </Border>
                        <StackPanel Grid.Column="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Hash" Width="45"/>
                                <TextBox Text="{Binding ParamIdHex, Mode=OneWay}" IsReadOnly="True" Width="150" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Name" Width="45"/>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}" Width="180"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Base" Width="45"/>
                                <TextBox Text="{Binding BaseHex, Mode=OneWay}" IsReadOnly="True" Width="110" FontFamily="Consolas"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Medal" Width="45"/>
                                <TextBox Text="{Binding Medal}" Width="60"/>
                                <CheckBox Content="Show" IsChecked="{Binding Show}" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Grid>

                    <TabControl>
                        <!-- ================= Stat and Moveset ================= -->
                        <TabItem Header="Stat and Moveset">
                            <StackPanel Margin="8">
                                <!-- Stats -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="50"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition/><RowDefinition/><RowDefinition/>
                                    </Grid.RowDefinitions>
                                    <TextBlock Grid.Row="0" Grid.Column="1" Text="HP" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Strength" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="3" Text="Spirit" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="4" Text="Defense" Style="{StaticResource Lbl}"/>
                                    <TextBlock Grid.Row="0" Grid.Column="5" Text="Speed" Style="{StaticResource Lbl}"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Min"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding MinHp}" Margin="2"/>
                                    <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding MinStrength}" Margin="2"/>
                                    <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding MinSpirit}" Margin="2"/>
                                    <TextBox Grid.Row="1" Grid.Column="4" Text="{Binding MinDefense}" Margin="2"/>
                                    <TextBox Grid.Row="1" Grid.Column="5" Text="{Binding MinSpeed}" Margin="2"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Max"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding MaxHp}" Margin="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding MaxStrength}" Margin="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding MaxSpirit}" Margin="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="4" Text="{Binding MaxDefense}" Margin="2"/>
                                    <TextBox Grid.Row="2" Grid.Column="5" Text="{Binding MaxSpeed}" Margin="2"/>
                                </Grid>

                                <!-- Power scale -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Puissance" VerticalAlignment="Center"/>
                                    <Slider x:Name="PowerSlider" Minimum="1" Maximum="10" Width="220" Value="5"
                                            TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                            VerticalAlignment="Center" Margin="6,0,0,0"/>
                                    <TextBlock Text="{Binding Value, ElementName=PowerSlider, StringFormat=N0}" Width="24"
                                               VerticalAlignment="Center" Margin="6,0,0,0" FontWeight="Bold"/>
                                    <Button Content="Appliquer stats cohérentes" Padding="8,2" Margin="10,0,0,0"
                                            Click="ApplyPower_Click"/>
                                </StackPanel>

                                <!-- Attributes -->
                                <GroupBox Header="Attribute Damage Multiplicator" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="Resistance" Width="75"/>
                                        <ComboBox Width="150" ItemsSource="{x:Static yk:YokaiEnums.Attributes}"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Resistance}"/>
                                        <TextBlock Text="Weakness" Width="75" Margin="20,0,0,0"/>
                                        <ComboBox Width="150" ItemsSource="{x:Static yk:YokaiEnums.Attributes}"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name"
                                                  SelectedValue="{Binding Weakness}"/>
                                    </StackPanel>
                                </GroupBox>

                                <!-- Moves -->
                                <GroupBox Header="Moves" Margin="0,10,0,0">
                                    <Grid Margin="4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="95"/>
                                            <ColumnDefinition Width="70"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition/><RowDefinition/><RowDefinition/>
                                            <RowDefinition/><RowDefinition/><RowDefinition/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Grid.Row="0" Grid.Column="0" Text="Attack"/>
                                        <ComboBox x:Name="AttackCombo" Grid.Row="0" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="0" Grid.Column="2" Text="{Binding AttackHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>
                                        <TextBox Grid.Row="0" Grid.Column="3" Text="{Binding AttackPct}" Margin="4,1,0,1"/>

                                        <TextBlock Grid.Row="1" Grid.Column="0" Text="Technique"/>
                                        <ComboBox x:Name="TechCombo" Grid.Row="1" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="1" Grid.Column="2" Text="{Binding TechniqueHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>
                                        <TextBox Grid.Row="1" Grid.Column="3" Text="{Binding TechniquePct}" Margin="4,1,0,1"/>

                                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Inspirit"/>
                                        <ComboBox x:Name="InspiritCombo" Grid.Row="2" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="2" Grid.Column="2" Text="{Binding InspiritHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>
                                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding InspiritPct}" Margin="4,1,0,1"/>

                                        <TextBlock Grid.Row="3" Grid.Column="0" Text="Guard"/>
                                        <ComboBox x:Name="GuardCombo" Grid.Row="3" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="3" Grid.Column="2" Text="{Binding GuardHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>
                                        <TextBox Grid.Row="3" Grid.Column="3" Text="{Binding GuardPct}" Margin="4,1,0,1"/>

                                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Soultimate"/>
                                        <ComboBox x:Name="SoulCombo" Grid.Row="4" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="4" Grid.Column="2" Text="{Binding SoultimateHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>

                                        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ability"/>
                                        <ComboBox x:Name="AbilityCombo" Grid.Row="5" Grid.Column="1" Margin="0,1"/>
                                        <TextBox Grid.Row="5" Grid.Column="2" Text="{Binding AbilityHex, Mode=OneWay}" IsReadOnly="True" FontFamily="Consolas" FontSize="10"/>
                                    </Grid>
                                </GroupBox>

                                <GroupBox Header="Profil d'attaque (élément + puissance ci-dessus)" Margin="0,10,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="Élément" VerticalAlignment="Center"/>
                                        <ComboBox x:Name="ProfileElementCombo" Width="120" Margin="6,0,0,0"
                                                  ItemsSource="{x:Static yk:YokaiEnums.Attributes}"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name"/>
                                        <CheckBox x:Name="ProfileBtCheck" Content="Blaster T aussi" IsChecked="True"
                                                  VerticalAlignment="Center" Margin="16,0,0,0"/>
                                        <Button Content="Appliquer le profil" Padding="8,2" Margin="16,0,0,0" Click="ApplyProfile_Click"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>

                        <!-- ================= Blaster T ================= -->
                        <TabItem Header="Blaster T">
                            <Grid Margin="8" IsEnabled="{Binding HasBlasterT}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="110"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Attaque A"/>
                                <ComboBox x:Name="BtAtkACombo" Grid.Row="0" Grid.Column="1" IsTextSearchEnabled="True" Margin="0,2"
                                          SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding BtAttackAHash}"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Attaque Y"/>
                                <ComboBox x:Name="BtAtkYCombo" Grid.Row="1" Grid.Column="1" IsTextSearchEnabled="True" Margin="0,2"
                                          SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding BtAttackYHash}"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Attaque X"/>
                                <ComboBox x:Name="BtAtkXCombo" Grid.Row="2" Grid.Column="1" IsTextSearchEnabled="True" Margin="0,2"
                                          SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding BtAttackXHash}"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Soultimate"/>
                                <ComboBox x:Name="BtSoulCombo" Grid.Row="3" Grid.Column="1" IsTextSearchEnabled="True" Margin="0,2"
                                          SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding BtSoultimateHash}"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Ability"/>
                                <ComboBox x:Name="BtAbilityCombo" Grid.Row="4" Grid.Column="1" IsTextSearchEnabled="True" Margin="0,2"
                                          SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding BtAbilityHash}"/>
                            </Grid>
                        </TabItem>

                        <!-- ================= Drops ================= -->
                        <TabItem Header="Drops">
                            <StackPanel Margin="8" IsEnabled="{Binding HasDrops}">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Argent" Width="70"/>
                                    <TextBox Text="{Binding Money}" Width="80"/>
                                    <TextBlock Text="Exp" Width="40" Margin="16,0,0,0"/>
                                    <TextBox Text="{Binding Experience}" Width="80"/>
                                </StackPanel>
                                <GroupBox Header="Drop 1">
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="Objet" Width="60"/>
                                        <ComboBox x:Name="Drop1Combo" Width="200" IsTextSearchEnabled="True"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding Drop1Hash}"/>
                                        <TextBlock Text="Taux %" Width="55" Margin="16,0,4,0"/>
                                        <TextBox Text="{Binding Drop1Rate}" Width="60"/>
                                    </StackPanel>
                                </GroupBox>
                                <GroupBox Header="Drop 2" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="Objet" Width="60"/>
                                        <ComboBox x:Name="Drop2Combo" Width="200" IsTextSearchEnabled="True"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name" SelectedValue="{Binding Drop2Hash}"/>
                                        <TextBlock Text="Taux %" Width="55" Margin="16,0,4,0"/>
                                        <TextBox Text="{Binding Drop2Rate}" Width="60"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>

                        <!-- ================= Trait ================= -->
                        <TabItem Header="Trait">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                    <TextBlock Text="Tribe" Width="60"/>
                                    <ComboBox Width="150" ItemsSource="{x:Static yk:YokaiEnums.Tribes}"
                                              SelectedValuePath="Key" DisplayMemberPath="Name" SelectedValue="{Binding Tribe}"/>
                                    <TextBlock Text="Rank" Width="50" Margin="20,0,0,0"/>
                                    <ComboBox Width="100" ItemsSource="{x:Static yk:YokaiEnums.Ranks}"
                                              SelectedValuePath="Key" DisplayMemberPath="Name" SelectedValue="{Binding Rank}"/>
                                </StackPanel>
                                <GroupBox Header="Évolution" Margin="0,0,0,6">
                                  <StackPanel Margin="4">
                                    <CheckBox x:Name="EvolvableCheck" Content="Évoluable" Margin="0,0,0,6"
                                              Checked="EvolvableCheck_Changed" Unchecked="EvolvableCheck_Changed"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Évolue en"/>
                                        <ComboBox x:Name="EvolveCombo" Width="180" IsTextSearchEnabled="True"
                                                  SelectedValuePath="Key" DisplayMemberPath="Name" TextSearch.TextPath="Name"
                                                  SelectedValue="{Binding EvolveTargetHash}" IsEnabled="{Binding CanEvolve}"/>
                                        <TextBlock Text="au niveau" Margin="12,0,4,0"/>
                                        <TextBox Text="{Binding EvolveLevel}" Width="45" IsEnabled="{Binding CanEvolve}"/>
                                        <TextBlock Text="{Binding EvolvesToName}" Margin="12,0,0,0" Foreground="#888"/>
                                    </StackPanel>
                                  </StackPanel>
                                </GroupBox>
                                <TextBlock Text="Description" Margin="0,4,0,2"/>
                                <TextBox Text="{Binding Description, UpdateSourceTrigger=LostFocus}" AcceptsReturn="True"
                                         TextWrapping="Wrap" Height="90" VerticalScrollBarVisibility="Auto"/>
                                <GroupBox Header="Scale (chara_scale)" Margin="0,10,0,0">
                                  <StackPanel Margin="4">
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                        <TextBlock Text="Morphologie" VerticalAlignment="Center"/>
                                        <Slider x:Name="MorphoSlider" Minimum="1" Maximum="10" Width="200" Value="1"
                                                TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                                                VerticalAlignment="Center" Margin="6,0,0,0"
                                                ValueChanged="MorphoSlider_ValueChanged"/>
                                        <TextBlock x:Name="MorphoLabel" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   FontWeight="Bold" MinWidth="140"/>
                                        <Button Content="Appliquer" Padding="8,2" Margin="8,0,0,0" Click="ApplyMorpho_Click"/>
                                    </StackPanel>
                                    <TextBlock Text="Jibanyan (Nyan) → Usapyon (mascotte) → Mark Evans (humain) → Enma (humanoïde)"
                                               Foreground="#888" FontSize="10" Margin="0,0,0,4"/>
                                    <WrapPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="1"/><TextBox Text="{Binding Scale1}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="2"/><TextBox Text="{Binding Scale2}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="3"/><TextBox Text="{Binding Scale3}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="4"/><TextBox Text="{Binding Scale4}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="5"/><TextBox Text="{Binding Scale5}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="6"/><TextBox Text="{Binding Scale6}" Width="70"/></StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,10,4"><TextBlock Text="7"/><TextBox Text="{Binding Scale7}" Width="70"/></StackPanel>
                                    </WrapPanel>
                                  </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>

                        <!-- ================= Charabase ================= -->
                        <TabItem Header="Charabase">
                            <StackPanel Margin="8">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                    <TextBlock Text="Modèle"/>
                                    <TextBox Text="{Binding ModelName, UpdateSourceTrigger=LostFocus}" Width="90" FontFamily="Consolas"/>
                                    <Border Width="48" Height="48" BorderBrush="#999" BorderThickness="1" Background="#F0F0F0" Margin="16,0,0,0">
                                        <Image x:Name="MedalIconImage" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center" Margin="4,0,0,0">
                                        <TextBlock Text="medal_icon" Foreground="#888" FontSize="10"/>
                                        <Button Content="Remplacer (PNG)" FontSize="10" Padding="4,1" Click="ReplaceMedalIcon_Click"/>
                                    </StackPanel>
                                </StackPanel>

                                <GroupBox Header="Status">
                                    <WrapPanel Margin="4">
                                        <CheckBox Content="Rare" IsChecked="{Binding IsRare}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Deva" IsChecked="{Binding IsDeva}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Legend" IsChecked="{Binding IsLegend}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Classic" IsChecked="{Binding IsClassic}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Mystery" IsChecked="{Binding IsMystery}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Pionner" IsChecked="{Binding IsPionner}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Merican" IsChecked="{Binding IsMerican}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Treasure" IsChecked="{Binding IsTreasure}" Width="95" Margin="0,2"/>
                                        <CheckBox Content="Commandant" IsChecked="{Binding IsCommandant}" Width="95" Margin="0,2"/>
                                    </WrapPanel>
                                </GroupBox>

                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock Text="Role" Width="60"/>
                                    <ComboBox Width="130" ItemsSource="{x:Static yk:YokaiEnums.Roles}"
                                              SelectedValuePath="Key" DisplayMemberPath="Name" SelectedValue="{Binding Role}"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <TextBlock Text="Favori" Width="60"/>
                                    <ComboBox Width="150" ItemsSource="{x:Static yk:YokaiEnums.Foods}"
                                              SelectedValuePath="Key" DisplayMemberPath="Name" SelectedValue="{Binding FavoriteFood}"/>
                                    <TextBlock Text="Détesté" Width="60" Margin="16,0,0,0"/>
                                    <ComboBox Width="150" ItemsSource="{x:Static yk:YokaiEnums.Foods}"
                                              SelectedValuePath="Key" DisplayMemberPath="Name" SelectedValue="{Binding HatedFood}"/>
                                </StackPanel>

                                <GroupBox Header="Medal (mini-icône dans l'atlas face_icon.xi)" Margin="0,8,0,0">
                                    <StackPanel Orientation="Horizontal" Margin="4">
                                        <TextBlock Text="X"/>
                                        <TextBox Text="{Binding MedalPosX, UpdateSourceTrigger=LostFocus}" Width="45" Margin="4,0"/>
                                        <TextBlock Text="Y" Margin="8,0,0,0"/>
                                        <TextBox Text="{Binding MedalPosY, UpdateSourceTrigger=LostFocus}" Width="45" Margin="4,0"/>
                                        <Border Width="48" Height="48" BorderBrush="#999" BorderThickness="1" Background="#F0F0F0" Margin="12,0,0,0">
                                            <Image x:Name="MedalAtlasImage" RenderOptions.BitmapScalingMode="NearestNeighbor"/>
                                        </Border>
                                        <Button Content="Choisir dans l'atlas…" Padding="6,2" Margin="6,0,0,0" VerticalAlignment="Center" Click="PickMedal_Click"/>
                                        <Button Content="Remplacer par PNG" Padding="6,2" Margin="6,0,0,0" VerticalAlignment="Center" Click="ReplaceMedalAtlas_Click"/>
                                    </StackPanel>
                                </GroupBox>
                            </StackPanel>
                        </TabItem>

                        <!-- ================= Quotes ================= -->
                        <TabItem Header="Quotes">
                            <TextBlock Margin="12" Foreground="#888"
                                       Text="Les citations (befriend quotes) seront ajoutées ultérieurement."/>
                        </TabItem>
                    </TabControl>
                </StackPanel>
            </ScrollViewer>
        </GroupBox>
    </DockPanel>
</Window>
